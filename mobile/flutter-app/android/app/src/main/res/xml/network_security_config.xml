<?xml version="1.0" encoding="utf-8"?>
<!--
    Network security config for SoHoLINK Node Dashboard.

    Allows cleartext (HTTP) connections to:
      • 10.0.2.2        — Android emulator loopback (maps to host localhost)
      • 192.168.0.0/16  — Private Class-C / home LAN
      • 10.0.0.0/8      — Private Class-A (corporate / VPN LAN)
      • 172.16.0.0/12   — Private Class-B

    All other traffic defaults to the platform's normal certificate pinning
    and HTTPS requirements — this config only relaxes LAN addresses.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator host -->
        <domain includeSubdomains="false">10.0.2.2</domain>

        <!-- RFC-1918 private address ranges -->
        <domain includeSubdomains="false">192.168.0.0</domain>
        <domain includeSubdomains="true">192.168.1.0</domain>
        <domain includeSubdomains="false">10.0.0.0</domain>
        <domain includeSubdomains="false">172.16.0.0</domain>
    </domain-config>

    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
